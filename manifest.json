{
  "manifest_version": 3,
  "name": "Runway 队列助手",
  "version": "1.0.0",
  "description": "自动将提示词队列提交到 Runway 生成",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://app.runwayml.com/*",
    "https://*.runwayml.com/*",
    "https://*.runwayai.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.runwayml.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  }
}